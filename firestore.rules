rules_version = '2';

// Deploy via Firebase Console or: firebase deploy --only firestore:rules
// See docs/FIRESTORE_DEPLOY.md

service cloud.firestore {
  match /databases/{database}/documents {

    // User-scoped data: only the authenticated user may read/write their own subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default (adjust if you add shared collections).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
