rules_version = '2';

// Deploy via Firebase Console or: firebase deploy --only firestore:rules
// See docs/FIRESTORE_DEPLOY.md

service cloud.firestore {
  match /databases/{database}/documents {

    // User-scoped data: only the authenticated user may read/write their own subtree.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Community posts: any authenticated user can read; only authors can create/delete.
    match /community_posts/{post} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.body.size() <= 500;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Scans: only the authenticated user can create/read their own scans.
    match /scans/{scan} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Feedback and Expert Requests: authenticated users can create.
    match /feedback/{item} {
      allow create: if request.auth != null;
    }
    match /expert_requests/{request} {
      allow create: if request.auth != null;
    }

    // Outbreak reports: authenticated users can read; authors create their own.
    match /outbreak_reports/{report} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // Treatment plans synced to cloud.
    match /treatments/{treatment} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
